# ============================================================
# ATHENA — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Full connection string used by the API and migration runner.
DATABASE_URL=postgres://athena_app:devpassword@localhost:5432/athena_db

# Used by docker-compose.dev.yml to set the postgres container password.
# Must match the password in DATABASE_URL.
POSTGRES_PASSWORD=devpassword

# ── Auth / JWT ────────────────────────────────────────────────
# Minimum 64 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_64_random_hex_chars

# Short-lived access token lifetime (e.g. 15m, 1h)
JWT_EXPIRY=15m

# ── OAuth — Google ────────────────────────────────────────────
# Register at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://<domain>/auth/callback/google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ── OAuth — Microsoft ─────────────────────────────────────────
# Register at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Authorised redirect URI: https://<domain>/auth/callback/microsoft
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=

# ── OAuth shared ──────────────────────────────────────────────
# Full URL to the /auth/callback/:provider route served by the API.
OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Public base URL of the deployed application (used for redirect-after-login).
APP_BASE_URL=http://localhost:5173

# ── Email (SMTP) ──────────────────────────────────────────────
# Used by nodemailer for quarantine alert emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── API ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
