{
    "name": "athena",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "apps/api",
        "apps/web",
        "apps/database"
    ],
    "scripts": {
        "migrate:dev": "npm run migrate --workspace=apps/database -- --env dev",
        "migrate:test": "npm run migrate --workspace=apps/database -- --env test",
        "migrate:prod": "npm run migrate --workspace=apps/database -- --env prod",
        "seed:dev": "npm run seed --workspace=apps/database",
        "dev:api": "npm run dev --workspace=apps/api",
        "dev:web": "npm run dev --workspace=apps/web",
        "dev": "concurrently --names \"api,web\" --prefix-colors \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:web\""
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}