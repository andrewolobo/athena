# ============================================================
# ATHENA — Root .gitignore
# Covers the monorepo root and all workspaces.
# ============================================================

# ── Environment & secrets ─────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Node ─────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Editors ──────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── TypeScript build output ───────────────────────────────────
dist/
*.tsbuildinfo

# ── SvelteKit ────────────────────────────────────────────────
apps/web/.svelte-kit/
apps/web/build/

# ── Docker ───────────────────────────────────────────────────
.dockerignore

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Misc ─────────────────────────────────────────────────────
.cache/
.temp/
tmp/
